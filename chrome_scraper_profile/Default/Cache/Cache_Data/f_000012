___CSS_LOADER_EXPORT___.push([module.id, `.maropost-app .loader-row:not(.legacy-app *){height:100%}.maropost-app .content-area:not(.legacy-app *){height:calc(100vh - 64px)!important;overflow:auto;background:#fafafa}.maropost-app .index:not(.legacy-app *){z-index:10!important}`, "",{"version":3,"sources":["webpack://./src/lib/layouts/AppLayout.vue"],"names":[],"mappings":"AAkYA,6CACE,WACF,CAMA,+CACE,mCAAqC,CACrC,aAAc,CACd,kBACF,CACA,wCACE,oBACF","sourcesContent":["<!--\n * App Layout\n * --------------------\n * Main layout component for the shell application.\n * Responsible for rendering the global structure of the app including:\n *\n *  - Application header\n *  - Left navigation (product-specific)\n *  - Micro-frontend (MFE) content outlet\n *  - Global SPA loader (store-driven)\n *\n * Responsibilities:\n *  1. Waits until all micro frontends signal readiness via `shellReady`.\n *  2. Dynamically loads the correct sidebar menu based on the current route.\n *     - Shows the menu only for product routes:\n *         • /accounts  → Marketing menu\n *         • /service   → Service menu\n *         • /commerce  → Commerce menu\n *  3. Reactively updates the menu when the route changes\n *     without reloading the application.\n *  4. Displays a global Vuetify loader during SPA route transitions\n *     and micro-frontend loading (controlled via Pinia store).\n *\n * Implementation details:\n *  - Uses `createMenuForRoute()` from `unifiedMenu.ts`.\n *  - Uses Vuetify `v-overlay` + `v-progress-circular`.\n *  - Compatible with Vue 3 + single-spa shell architecture.\n *\n * @author Harvinder Singh <harvinder@maropost.com>\n * @created 2025-09-30\n * @updated 2026-02-10\n -->\n\n <template>\n  <div>\n    <!-- ===============================================================\n         GLOBAL HEADER\n         =============================================================== -->\n    <TheHeader />\n\n    <!-- ===============================================================\n         TRIAL BANNER\n         =============================================================== -->\n\n    <div\n      v-if=\"trialDays && trialDays.maxDays && showBanner\"\n      class=\"trial-banner\"\n    >\n        <v-icon size=\"18\">\n          mdi-information-outline\n        </v-icon>\n        <div class=\"trial-text\">   {{isTrialExpired ? 'Trial Ended' : 'Trial: ' + trialDays.maxDays + ' left until your trial ends.'}}</div>\n\n      <a href=\"#\" @click=\"navigateToBilling\" class=\"trial-link\">BUY NOW</a>\n\n      <v-icon size=\"16\" class=\"trial-close-icon\" @click=\"hideBanner\">\n          mdi-close\n        </v-icon>\n    </div>\n    \n    <!-- ===============================================================\n         GLOBAL SPA LOADER\n         =============================================================== -->\n         <v-overlay\n            :model-value=\"loading\"\n            class=\"spa-loader\"\n            persistent\n            width=\"100%\"\n            height=\"100%\"\n            opacity=\"0.25\"\n          >\n          <v-row justify=\"center\" align=\"center\" class=\"loader-row\">\n              <v-progress-circular\n                indeterminate\n                size=\"48\"\n                width=\"4\"\n                color=\"primary\"\n              />\n            </v-row>\n          </v-overlay>\n    <!-- ===============================================================\n         APPLICATION LAYOUT\n         =============================================================== -->\n    <v-main class=\"mt-16\">\n      <v-row no-gutters>\n        <!-- -----------------------------------------------------------\n             LEFT NAVIGATION\n             Rendered only when product menu is available\n        ------------------------------------------------------------ -->\n        <v-col cols=\"auto\" v-if=\"showNavigation\">\n          <TheUnifiedNavigation\n            class=\"mt-16 content-area index\"\n            :account-id=\"userStore.getAccountId\" \n            :nav-blocks=\"navigation\" \n            :enableStoreMenu=\"saleNavigation\"\n            :collapsed=\"userStore.isNavigationRail\"\n            @update:collapsed=\"toggleLeftMenu\"\n          >\n          <template #store-control>\n            <div id=\"sale-channel-navigation\"></div> \n          </template>\n          <template #top-block>\n            <OnboardingMenu />\n          </template>\n          </TheUnifiedNavigation>\n        </v-col>\n\n        <!-- -----------------------------------------------------------\n             MAIN CONTENT AREA\n        ------------------------------------------------------------ -->\n        <v-col cols=\"12\">\n          <div class=\"content-area\">\n            <DrawerHost ref=\"drawerRef\" />\n\n            <router-view />\n          </div>\n        </v-col>\n      </v-row>\n\n      <AlertModal :show=\"alertModalState.show\" :state=\"alertModalItems\" @confirm=\"handleAlertConfirm\"  @cancel=\"alertModalService.hide()\" />\n    </v-main>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\n/**\n * ============================================================================\n * Unified Shell – Navigation & Loader Controller\n * ============================================================================\n *\n * Behavior Summary\n * ----------------\n * - Displays unified navigation ONLY for supported product routes\n *   (Marketing, Service, Commerce).\n * - Navigation menu is loaded lazily and reacts to route changes.\n * - Global loader visibility is controlled via cross-MFE events.\n *\n * Communication Model\n * -------------------\n * - MFEs dispatch `MFE_LOADED` events to signal loading state.\n * - Shell listens and updates `loading` accordingly.\n * - MFEs can also request navigation rail changes via custom events.\n *\n * Design Notes\n * ------------\n * - Shell remains framework-agnostic.\n * - MFEs do not directly import shell dependencies.\n * - All UI side-effects are centralized here.\n * ============================================================================\n */\n\nimport { computed, onMounted, ref, watch } from \"vue\";\nimport { useRoute, useRouter } from \"vue-router\";\nimport { navigateToUrl } from \"single-spa\";\n\n/* ---------------------------------------------------------------------------\n * UI Components\n * ---------------------------------------------------------------------------\n */\nimport { TheHeader, DrawerHost } from \"../components\";\nimport {\n  TheUnifiedNavigation,\n  AlertModal,\n  GenericModalState,\n} from \"@maropost-ui/liquidsky-ui\";\nimport OnboardingMenu from \"../components/onboarding/NavigationMenu.vue\";\n\n/* ---------------------------------------------------------------------------\n * Stores & Services\n * ---------------------------------------------------------------------------\n */\nimport { useUserStore } from \"../stores\";\nimport { useNavigation } from \"../composable/sidemenu/unifiedNavigation\";\nimport { alertModalService } from \"@/lib/services/alertModalService\";\nimport { onBoardingService } from \"@/lib/services/onBoardingService\";\nimport { shouldFetchOnboardingData } from \"@/lib/utils/onboardingAccess\";\nimport { useHubSpotChat } from \"@/lib/plugins/hubspotChat\";\n\nimport { useGlobalTrialState } from \"../composable/freeTrail/useGlobalTrialState\";\n\n/* ============================================================================\n * STORES & ROUTER\n * ============================================================================\n */\n\n// User / permissions store\nconst userStore = useUserStore();\n\n// Vue Router instance\nconst router = useRouter();\nconst route = useRoute();\n\n// Global alert modal reactive state\nconst alertModalState = alertModalService.getState();\n\n// Global loader state (controlled by MFEs)\nconst loading = ref(false);\n\n// Show banner state\nconst showBanner = computed(() => userStore.getCTABanner);\nconst hubSpotChat = useHubSpotChat();\n\n/**\n * Load HubSpot chat after the shell loader is idle (initial mount or MFE finished).\n */\nconst loadHubSpotWhenIdle = (): void => {\n  if (!loading.value) {\n    hubSpotChat.loadIfEnabled();\n  }\n};\n\nonMounted(loadHubSpotWhenIdle);\n\nwatch(loading, loadHubSpotWhenIdle, { flush: \"post\" });\n\n// Sales navigation visibility (permission-based)\nconst saleNavigation = computed(() => userStore.getSaleNavigation);\n\n// Normalized alert modal props\nconst alertModalItems = computed<GenericModalState>(() => ({\n  title: alertModalState.title,\n  subtitle: alertModalState.subtitle,\n  description: alertModalState.description,\n}));\n\n  /**\n   * Get the trial data\n   */\n  const trialData:any = computed(() => userStore.getTrailPackageFeatures);\n\n  /**\n   * Use the trial countdown composable\n   */\n\n  const { trialDays } = useGlobalTrialState(\n    trialData,\n    userStore\n  );\n\n  /**\n   * Hide the banner\n   */\n  const hideBanner = () => {\n    userStore.setCTABanner(false);\n  }\n\n  /**\n   * Navigate to the billing page\n   */\n  const navigateToBilling = () => {\n    \n    let accountId = userStore.getAccountId\n     navigateToUrl(`/accounts/${accountId}/account-&-billing/subscriptions`)\n  }\n\n  /**\n   * Check if the trial is expired\n   */\n   const isTrialExpired = computed(() => userStore.getIsTrailAccount && userStore.getIsTrialExpired);\n\n\n   /**\n    * \n    */\n   const isNetoMhcAccountTraialExpired = computed(() => userStore.getIsTrailAccount && userStore.getIsTrialExpired && !userStore.getProductAccess('neto') && !userStore.getProductAccess('mhc'));\n\n/**\n * Left navigation visibility.\n * Hidden on routes that opt out via meta (e.g. account setup) or when\n * a Neto/MHC trial account has expired.\n */\nconst showNavigation = computed(() => {\n  const navigationEnabled = (route.meta.navigation as { show?: boolean } | undefined)?.show !== false\n  return navigationEnabled && !isNetoMhcAccountTraialExpired.value\n});\n\n/