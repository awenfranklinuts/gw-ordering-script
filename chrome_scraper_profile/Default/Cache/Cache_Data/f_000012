sCircularBind\"\n                  class=\"mr-2 flex-shrink-0\"\n                />\n                {{ completedStepsDisplay }}/{{ totalStepsDisplay }} Completed\n              </div>\n            </v-list-item-title>\n          </template>\n        </v-list-item>\n      </template>\n    </v-tooltip>\n    <v-divider />\n  </div>\n</template>\n\n<script setup lang=\"ts\">\n  import { computed } from 'vue';\n  import { navigateToUrl } from 'single-spa';\n  import { useUserStore } from '@/lib/stores';\n  import { onBoardingService } from '@/lib/services/onBoardingService';\n\n  const ONBOARDING_PRODUCTS = ['marketing', 'service', 'commerce'] as const;\n\n  const userStore = useUserStore();\n\n  const isCollapsed = computed(() => userStore.isNavigationRail);\n\n  const progressCircularBind = computed(() => ({\n    modelValue: onBoardingService.getOnboardingCompletedPercentage.value ?? 0,\n    size: 22,\n    width: 3,\n    color: 'mpBlue',\n    bgColor: 'grey',\n  }));\n\n  const completedStepsDisplay = computed(\n    () => onBoardingService.getOnboardingCompletedSteps.value ?? 0,\n  );\n\n  const totalStepsDisplay = computed(\n    () => onBoardingService.getOnboardingTotalSteps.value ?? 0,\n  );\n\n  const isOnboardingAvailable = computed(() => {\n    const hasAccess = ONBOARDING_PRODUCTS.some((product) =>\n      userStore.getProductAccess(product),\n    );\n    return hasAccess && !onBoardingService.isOnboardingCompleted.value;\n  });\n\n  function openOnboarding() {\n    navigateToUrl(`/accounts/${userStore.getAccountId}/onboarding`);\n  }\n</script>\n\n<style scoped>\n  .steps-count {\n    font-size: 8px;\n  }\n\n  .onboarding-menu-item {\n    padding: unset !important;\n    padding-left: 8px !important;\n  }\n\n  .onboarding-item-title {\n    display: grid;\n    align-items: center;\n    justify-items: center;\n  }\n  \n  .onboarding-item-title-expanded {\n    padding-left: 14px;\n  }\n</style>\n"],"sourceRoot":""}]);
