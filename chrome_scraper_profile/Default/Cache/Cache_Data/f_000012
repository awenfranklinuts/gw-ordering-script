DefaultLayout from '@/lib/layouts/DefaultLayout.vue'\nimport AuthLayout from '@/lib/layouts/AuthLayout.vue'\n\n/* UI */\nimport { SplashScreen } from '@/lib/components'\n\n/* Stores */\nimport { useUserStore } from '@/lib/stores'\n\n/* Services */\nimport {\n  $accountService,\n  useMarketingService,\n  useMhcService,\n  useNotificationService,\n} from '@/lib/services'\n\n/* Config & Utils */\nimport { AppConfig } from '@/lib/config'\nimport { markShellReady } from './lib/config/spa/shell-ready'\nimport { createSplitFactory } from './lib/composable/split.io/splitClient'\n\nimport {\n  verifyAccountCluster,\n} from './lib/utils/utils'\n\nimport {\n  fetchAccounts,\n  fetchAccountIdFromUrl,\n  findAccountFromAccounts,\n  isProvisioningIncomplete,\n} from './lib/utils/accounts'\n\nimport {\n  getCombinedFeatures,\n  checkFreetrailAccount,\n} from './lib/utils/features'\n\nimport {\n  getAccountSwitchPath,\n  isActiveAccountPath,\n} from './lib/utils/shell'\n\nimport { getAmplitudeService } from '@/lib/services/amplitudeTrackingService'\n\n/* Auth */\nimport keycloak from './lib/plugins/keycloak-config'\n\n/* Routing */\nimport getDynamicRoutes from './lib/router/updateRoutes'\n\n/* ============================================================================\n * TYPES\n * ============================================================================\n */\n\ntype UserStore = ReturnType<typeof useUserStore>\n\n/* ============================================================================\n * CONSTANTS\n * ============================================================================\n */\n\nconst layouts = {\n  app: AppLayout,\n  default: DefaultLayout,\n  auth: AuthLayout,\n}\n\nconst PACKAGE_TO_PRODUCT_MAP: Record<string, string> = {\n  mmc: 'marketing',\n  msc: 'service',\n  mcc: 'commerce',\n}\n\nconst GENERIC_ERROR_MESSAGE = 'Something went wrong.'\n\nconst NO_ACCOUNT_MESSAGE =\n  'No linked account found for this user. Kindly contact Admin.'\n\n/* ============================================================================\n * STATE\n * ============================================================================\n */\n\nconst selectedLayout = ref<'app' | 'default' | 'auth'>('app')\nconst isAccountReady = ref(false)\n\nconst router = useRouter()\n\n/* ============================================================================\n * BOOTSTRAP ENTRY\n * ============================================================================\n */\n\nonMounted(async () => {\n  const userStore = useUserStore()\n\n  // Disable sales navigation by default\n  userStore.setSaleNavigation(false)\n\n  /* --------------------------------------------------------------------------\n   * STEP 1: AUTHENTICATION GUARD\n   * --------------------------------------------------------------------------\n   */\n  if (!keycloak || !keycloak.authenticated) {\n    selectedLayout.value = 'auth'\n    markApplicationReady()\n    return\n  }\n\n  /* --------------------------------------------------------------------------\n   * STEP 2: FAST ACCOUNT VALIDATION\n   * --------------------------------------------------------------------------\n   * If current URL already belongs to active account,\n   * bootstrap can skip some expensive operations.\n   */\n  let skipAccountBootstrap = false\n  if (\n    userStore.getAccountId &&\n    isActiveAccountPath(\n      window.location.pathname,\n      userStore.getAccountId.toString()\n    )\n  ) {\n    skipAccountBootstrap = true\n\n    verifyAccountClusterSafe(userStore.getDefaultAccount)\n\n    registerDynamicRoutes(userStore, router)\n  }\n\n  /* --------------------------------------------------------------------------\n   * STEP 3: LOAD USER PROFILE\n   * --------------------------------------------------------------------------\n   */\n  try {\n    await userStore.getUserData()\n  } catch (err) {\n    console.error('Failed to fetch user data:', err)\n  }\n\n  /* --------------------------------------------------------------------------\n   * STEP 4: FETCH LINKED ACCOUNTS\n   * --------------------------------------------------------------------------\n   */\n  let accounts: any[] = []\n\n  try {\n    accounts = await fetchAccounts()\n  } catch (err) {\n    redirectToIdentityDashboard(GENERIC_ERROR_MESSAGE)\n    return\n  }\n\n  /* --------------------------------------------------------------------------\n   * STEP 5: FETCH PRODUCT-ONLY ACCOUNTS\n   * --------------------------------------------------------------------------\n   * These products do not rely on core account packages.\n   */\n  await fetchStandaloneProductAccounts(userStore)\n\n  /* --------------------------------------------------------------------------\n   * STEP 6: HANDLE NO ACCOUNT FALLBACK\n   * --------------------------------------------------------------------------\n   */\n  if (!accounts?.length) {\n    redirectToOtherProduct(userStore)\n    return\n  }\n\n  /* --------------------------------------------------------------------------\n   * STEP 7: RESOLVE ACTIVE ACCOUNT\n   * --------------------------------------------------------------------------\n   */\n  const account = await resolveActiveAccount(userStore, accounts)\n\n  /* --------------------------------------------------------------------------\n   * STEP 8: VERIFY ACCOUNT CLUSTER\n   * --------------------------------------------------------------------------\n   */\n  if (!skipAccountBootstrap) {\n    verifyAccountClusterSafe(account)\n  }\n\n  /* --------------------------------------------------------------------------\n   * STEP 9: PERSIST ACCOUNT CONTEXT\n   * --------------------------------------------------------------------------\n   */\n  persistAccountContext(userStore, account, accounts)\n\n  /* --------------------------------------------------------------------------\n   * STEP 10: FETCH PACKAGE FEATURES\n   * --------------------------------------------------------------------------\n   */\n  try {\n    const response = await $accountService.fetchPackageFeatures()\n\n    const packageData = response.data.data\n\n    userStore.setTrailPackageFeatures(packageData)\n\n    userStore.setPackageFeatures(\n      getCombinedFeatures(\n        response.data,\n        userStore.isCustomerPreferredUid\n      )\n    )\n\n    const navigateToBilling = async () => {\n      registerDynamicRoutes(userStore, router)\n\n      await finalizeShellBootstrap()\n\n      router.push(\n        `/accounts/${userStore.getAccountId}/account-&-billing/subscriptions`\n      )\n    }\n\n    checkFreetrailAccount(\n      packageData,\n      userStore,\n      navigateToBilling\n    )\n\n    setUserAccessBasedOnPackage(packageData, userStore)\n\n    await setAmplitudeUser(userStore, account)\n\n    const hasMarketing = userStore.getProductAccess('marketing')\n    const hasService = userStore.getProductAccess('service')\n    const hasCommerce = userStore.getProductAccess('commerce')\n\n    const hasCoreProducts =\n      hasMarketing || hasService || hasCommerce\n\n    const isExpiredTrialWithoutStandaloneProducts =\n      userStore.getIsTrailAccount &&\n      userStore.getIsTrialExpired &&\n      !userStore.getProductAccess('neto') &&\n      !userStore.getProductAccess('mhc')\n\n    if (isExpiredTrialWithoutStandaloneProducts) {\n      return\n    }\n\n    if (!hasCoreProducts) {\n      if (accounts.length > 1 && !userStore.getIsTrailAccount) {\n        invalidAccount(account.id)\n        return\n      }\n\n      if (accounts.length) {\n        registerDynamicRoutes(userStore, router)\n      }\n\n      redirectToOtherProduct(userStore)\n      return\n    }\n  } catch (err) {\n    invalidAccount(account.id)\n\n    console.error('Failed to fetch package features:', err)\n\n    return\n  }\n\n  /* --------------------------------------------------------------------------\n   * STEP 11: INITIALIZE SPLIT.IO\n   * --------------------------------------------------------------------------\n   */\n  try {\n    await createSplitFactory()\n  } catch (err) {\n    console.error('Split.io initialization failed:', err)\n  }\n\n  /* --------------------------------------------------------------------------\n   * STEP 12: FETCH ROLES & MARKETING INFO\n   * --------------------------------------------------------------------------\n   */\n  try {\n    const marketingService = useMarketingService()\n\n    await Promise.all([\n      $accountService.fetchRoles(),\n      marketingService.fetchAccountInfo(),\n    ])\n\n    userStore.setRoles($accountService.roles.value)\n  } catch (err) {\n    console.error('Failed to fetch roles or marketing info:', err)\n\n    userStore.setSingleProductAccess('marketing', false)\n\n    // Prevent role-based access checks from failing\n    userStore.setRoles({ roles: [] })\n\n    if (!userStore.getProductAccess('commerce')) {\n      invalidAccount(account.id)\n      return\n    }\n  }\n\n  /* --------------------------------------------------------------------------\n   * STEP 13: FETCH NOTIFICATIONS\n   * --------------------------------------------------------------------------\n   */\n  const canLoadNotifications =\n    (\n      userStore.getProductAccess('marketing') &&\n      userStore.getProductAccessOnRoles('marketing')\n    ) ||\n    userStore.getProductAccess('commerce')\n\n  if (canLoadNotifications) {\n    try {\n      useNotificationService.fetchNotifications()\n    } catch (err) {\n      console.error('Failed to fetch notifications:', err)\n    }\n  }\n\n  /* --------------------------------------------------------------------------\n   * STEP 14: REGISTER DYNAMIC ROUTES\n   * --------------------------------------------------------------------------\n   */\n  if (!skipAccountBootstrap) {\n    registerDynamicRoutes(userStore, router)\n  }\n\n  /* --------------------------------------------------------------------------\n   * STEP 15: FINALIZE BOOTSTRAP\n   * --------------------------------------------------------------------------\n   */\n  await finalizeShellBootstrap()\n})\n\n/* ============================================================================\n * HELPERS\n * ============================================================================\n */\n\n/**\n * Marks application bootstrap as complete\n */\nconst markApplicationReady = () => {\n  isAccountReady.value = true\n}\n\n/**\n * Redirects user to identity dashboard with message\n */\nconst redirectToIdentityDashboard = (message: string) => {\n  const encodedMessage = encodeURIComponent(message)\n\n  window.location.replace(\n    `${AppConfig.IDENTITY_BASE_URL}/#/dashboard?code=400&message=${encodedMessage}`\n  )\n}\n\n/**\n * Resolve active account from:\n * 1. URL accountId\n * 2. Existing store account\n * 3. Default account\n * 4. First available account\n */\nconst resolveActiveAccount = async (\n  userStore: UserStore,\n  accounts: any[]\n) => {\n  const parsedAccountId = Number.parseInt(fetchAccountIdFromUrl())\n\n  const resolvedAccountId =\n    Number.isFinite(parsedAccountId) && parsedAccountId > 0\n      ? parsedAccountId\n      : userStore.getAccountId ||\n        userStore.getDefaultAccountId ||\n        accounts[0].id\n\n  return (\n    (await findAccountFromAccounts(accounts, resolvedAccountId)) ||\n    (await findAccountFromAccounts(\n      accounts,\n      userStore.getDefaultAccountId\n    )) ||\n    accounts[0]\n  )\n}\n\n/**\n * Persist account-related state\n */\nconst persistAccountContext = (\n  userStore: UserStore,\n  account: any,\n  accounts: any[]\n) => {\n  try {\n    userStore.setAccountId(account.id)\n    userStore.setDefaultAccount(account)\n    userStore.setAccounts(accounts)\n    userStore.setProductAccess(account)\n  } catch (err) {\n    console.error('Failed to persist account state:', err)\n  }\n}\n\n/**\n * Fetch Neto & MHC standalone accounts\n */\nconst fetchStandaloneProductAccounts = async (\n  userStore: UserStore\n) => {\n  const mhcService = useMhcService()\n\n  const [netoResult, mhcResult] = await Promise.allSettled([\n    $accountService.fetchNetoAccount({\n      params: { filters: 'neto/tenancies' },\n    }),\n    mhcService.findAll(),\n  ])\n\n  /* Neto */\n  if (netoResult.status === 'fulfilled') {\n    const netoAccounts =\n      $accountService.netoAccounts.value || []\n\n    userStore.setSingleProductAccess(\n      'neto',\n      netoAccounts.length > 0\n    )\n\n    userStore.setNetoStores(netoAccounts)\n  } else {\n    userStore.setSingleProductAccess('neto', false)\n\n    console.error(\n      'Failed to fetch Neto accounts:',\n      netoResult.reason\n    )\n  }\n\n  /* MHC */\n  if (mhcResult.status === 'fulfilled') {\n    userStore.setSingleProductAccess(\n      'mhc',\n      mhcService.items.value.length > 0\n    )\n\n    userStore.setMhcStores(mhcService.items.value)\n  } else {\n    userStore.setSingleProductAccess('mhc', false)\n\n    console.error(\n      'Failed to fetch MHC accounts:',\n      mhcResult.reason\n    )\n  }\n}\n\n/**\n * Disable product access when package missing\n */\nconst setUserAccessBasedOnPackage = (\n  packages: Record<string, any>,\n  userStore: UserStore\n) => {\n  if (!packages || typeof packages !== 'object') {\n    return\n  }\n\n  Object.entries(PACKAGE_TO_PRODUCT_MAP).forEach(\n    ([packageKey, productKey]) => {\n      const pkg = packages[packageKey]\n\n      if (!pkg || !pkg.package_name) {\n        userStore.setSingleProductAccess(productKey, false)\n      }\n    }\n  )\n}\n\n/**\n * Redirect user to product-specific dashboards\n */\nconst redirectToOtherProduct = (userStore: UserStore) => {\n  if (userStore.getProductAccess('neto')) {\n    setAmplitudeUser(userStore, {})\n\n    router.push('/neto/dashboard')\n\n    markApplicationReady()\n\n    return\n  }\n\n  if (userStore.getProductAccess('mhc')) {\n    router.push('/merchandising/dashboard')\n\n    markApplicationReady()\n\n    return\n  }\n\n  // check if the account provisioning is not completed\n  const provisioning = isProvisioningIncomplete()\n  if (provisioning) {\n    router.push('/account-setup')\n\n    markApplicationReady()\n    \n    return\n  }\n\n  redirectToIdentityDashboard(NO_ACCOUNT_MESSAGE)\n}\n\n/**\n * Handles invalid account redirect\n */\nconst invalidAccount = (id: string) => {\n  markApplicationReady()\n\n  selectedLayout.value = 'default'\n\n  router.push({\n    path: '/select-account',\n    query: { accountId: id },\n  })\n}\n\n/**\n * Safe wrapper around cluster verification\n */\nconst verifyAccountClusterSafe = (account: any) => {\n  try {\n    verifyAccountCluster(account)\n  } catch (err) {\n    console.error(\n      'Account cluster verification failed:',\n      err\n    )\n  }\n}\n\n/**\n * Register routes dynamically\n */\nconst registerDynamicRoutes = (\n  userStore: UserStore,\n  router: Router\n) => {\n  const dynamicRoutes = getDynamicRoutes(userStore, router)\n\n  for (const route of dynamicRoutes) {\n    if (route.name && !router.hasRoute(route.name)) {\n      router.addRoute(route)\n    }\n  }\n\n  if (\n    userStore.getIsTrailAccount &&\n    userStore.getIsTrialExpired\n  ) {\n    return\n  }\n\n  if (window.location.pathname === '/') {\n    /**\n     * If account is free trial account, redirect to onboarding if not completed, otherwise redirect to dashboard\n     */\n    const endpoint = userStore.getIsTrailAccount && !userStore.isOnboardingCompleted ? 'onboarding' : 'dashboard'\n    router.replace(\n      `/accounts/${userStore.getAccountId}/${endpoint}`\n    )\n\n    return\n  }\n\n  const currentPath = window.location.pathname\n\n  const newPath = getAccountSwitchPath(\n    currentPath,\n    userStore.getAccountId.toString()\n  )\n\n  const currentFullPath =\n    router.currentRoute.value.fullPath\n\n  if (currentFullPath !== newPath) {\n    router.replace({\n      path: newPath,\n      query: router.currentRoute.value.query\n    })\n  }\n}\n\n/**\n * Initialize amplitude user\n */\nconst setAmplitudeUser = async (\n  userStore: UserStore,\n  account?: any\n) => {\n  try {\n    const amplitudeService =\n      await getAmplitudeService()\n\n    amplitudeService.setUser(userStore, account)\n\n    if (!userStore.getIsLoggedIn) {\n      amplitudeService.trackEvent('User Logged In')\n    }\n\n    userStore.setIsLoggedIn(true)\n  } catch (err) {\n    console.error(\n      'Amplitude initialization failed:',\n      err\n    )\n  }\n}\n\n/**\n * Finalize shell bootstrap\n */\nconst finalizeShellBootstrap = async () => {\n  try {\n    await markShellReady()\n\n    markApplicationReady()\n\n    void import(\n      './lib/config/spa/single-spa-config'\n    ).catch(err =>\n      console.error(\n        'Failed to load single-spa config:',\n        err\n      )\n    )\n  } catch (err) {\n    console.error(\n      'Shell ready finalization failed:',\n      err\n    )\n\n    markApplicationReady()\n  }\n}\n\n</script>\n\n<style scoped>\n.v-application.theme--light {\n  color: rgba(0, 0, 0, 0.87);\n}\n\n.v-application.theme--dark {\n  color: rgba(255, 255, 255, 0.87);\n}\n</style>"],"sourceRoot":""}]);
